<div class="container mx-auto px-3.5">
	<div class="grid gap-x-4 lg:grid-cols-[1fr_2fr_1fr]">
		<section class="order-1 lg:col-start-1 lg:row-span-3" aria-label="Image">
			<div class="sticky top-[95px] flex flex-col overflow-hidden">
				<div id="product-gallery" class="carousel overflow-hidden">
					<div class="carousel-track">
						<div class="carousel-slide flex w-full shrink-0 justify-center">
							<img class="max-h-[356px] object-contain" src="{{ thumb }}" alt="{{ heading_title }}" />
						</div>

						{% if images %}
							{% for image in images %}
								<div class="carousel-slide flex w-full shrink-0 justify-center">
									<img class="max-h-[356px] object-contain" src="{{ image.popup ? : image.thumb }}" alt="{{ heading_title }}" />
								</div>
							{% endfor %}
						{% endif %}
					</div>
				</div>

				<div id="product-thumbs" class="mt-2 flex gap-1 overflow-x-auto p-2">
					<button type="button" class="gallery-thumb border-primary shrink-0 rounded-lg border p-1" data-index="0">
						<img class="h-15 object-contain" src="{{ thumb }}" alt="{{ heading_title }}" />
					</button>

					{% if images %}
						{% for image in images %}
							<button type="button" class="gallery-thumb shrink-0 rounded-lg border border-gray-400 p-1" data-index="{{ loop.index }}">
								<img class="h-15 object-contain" src="{{ image.thumb }}" alt="{{ heading_title }}" />
							</button>
						{% endfor %}
					{% endif %}
				</div>
			</div>
		</section>

		<section class="order-first max-sm:overflow-hidden lg:col-start-2 lg:row-start-1" aria-label="Breadcrumbs">
			{% include "tailwind/components/breadcrumbs.twig" with { class: "sm:flex-wrap sm:flex" } %}
		</section>

		<section class="order-3 lg:col-start-3 lg:row-span-3" aria-label="Buy">
			<div class="sticky top-[95px] flex flex-col gap-2 max-lg:pt-4">
				<p class="heading-3">
					{{ price }}
				</p>
				<div class="flex items-center gap-1">
					{% if quantity >= 1 %}
						<svg aria-hidden="true" class="text-green-800" height="16" width="16" viewbox="0 0 24 24">
							<use href="/assets/icons/sprite.svg#lucide-truck"></use>
						</svg>
						<p class="text-sm text-green-800">
							В наявності
						</p>
					{% else %}
						<svg aria-hidden="true" class="text-gray-600" height="16" width="16" viewbox="0 0 24 24">
							<use href="/assets/icons/sprite.svg#lucide-truck"></use>
						</svg>
						<p class="text-sm text-gray-600">
							Не в наявності
						</p>
					{% endif %}
					{% if book %}
						<span class="text-gray-600">•</span>
						<p class="text-sm text-gray-600">
							Паперова книга
						</p>
					{% endif %}
				</div>
				{% if quantity >= 1 %}
					<button class="button-primary">
						<svg aria-hidden="true" viewbox="0 0 24 24">
							<use href="/assets/icons/sprite.svg#icon-cart"></use>
						</svg>Купити
					</button>
				{% else %}
					<button class="button-secondary border border-gray-400" disabled>Немає в наявності</button>
				{% endif %}
				<div class="mt-2 flex flex-col gap-1 max-lg:hidden">
					<p class="text-md pb-1 font-bold">
						Доставка
					</p>
					<div class="py-1 text-sm">
						<div class="flex items-center gap-1">
							<svg aria-hidden="true" height="14" width="14" viewbox="0 0 12 16">
								<use href="/assets/icons/sprite.svg#icon-meest"></use>
							</svg>
							<p>
								Meest
							</p>
						</div>
						<p class="font-bold">
							Відправимо завтра
						</p>
					</div>
					<hr class="divider" />
					<div class="py-1 text-sm">
						<div class="flex items-center gap-1">
							<svg aria-hidden="true" height="14" width="14" viewbox="0 0 333 317">
								<use href="/assets/icons/sprite.svg#icon-ukrp" fill="#FFBE0C"></use>
							</svg>
							<p>
								Укрпошта
							</p>
						</div>
						<p class="font-bold">
							Відправимо завтра
						</p>
					</div>
					<hr class="divider" />
					<div class="py-1 text-sm">
						<div class="flex items-center gap-1">
							<svg aria-hidden="true" height="14" width="14" viewbox="0 0 16 16">
								<use href="/assets/icons/sprite.svg#icon-novaposhta"></use>
							</svg>
							<p>
								Нова пошта
							</p>
						</div>
						<p class="font-bold">
							Відправимо завтра
						</p>
					</div>
					<hr class="divider" />
					<div class="py-1 text-sm">
						<div class="flex items-center gap-1">
							<svg class="text-primary" aria-hidden="true" height="14" width="14" viewbox="0 0 16 16">
								<use href="/assets/icons/sprite.svg#lucide-store"></use>
							</svg>
							<p>
								Самовивіз
							</p>
						</div>
						<p class="font-bold">
							Без вихідних!
						</p>
					</div>
				</div>
				{# <div class="mt-2 flex flex-col gap-1">
					<p class="text-md pb-1 font-bold">
						Варіанти оплати
					</p>

					<div class="py-1 text-sm">
						<div class="flex items-center gap-1">
							<svg class="text-primary" aria-hidden="true" height="16" width="16" viewbox="0 0 12 16">
								<use href="/assets/icons/sprite.svg#lucide-credit-card"></use>
							</svg>
							<p>
								Оплата карткою онлайн (LiqPay)
							</p>
						</div>
					</div>
					<hr class="divider" />
					<div class="py-1 text-sm">
						<div class="flex items-center gap-1">
							<svg class="text-primary" aria-hidden="true" height="16" width="16" viewbox="0 0 12 16">
								<use href="/assets/icons/sprite.svg#lucide-circle-dollar-sign"></use>
							</svg>
							<p>
								Накладений платіж
							</p>
						</div>
					</div>
				</div> #}
			</div>
		</section>

		<section class="order-4 lg:col-start-2 lg:row-start-2" aria-label="Title">
			<div class="flex flex-col max-lg:pt-4">
				<h1 class="heading-2">{{ heading_title }}</h1>
				<p class="text-primary">
					{{ author }}
				</p>
				{% set rounded_rating = rating | split(".") | first %}

				<div class="my-1 flex items-center text-sm">
					<div class="mr-2 flex items-center gap-0.5">
						{% for i in 1..5 %}
							{% if rounded_rating >= i %}
								<svg class="size-3 text-orange-600" viewbox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<use href="/assets/icons/sprite.svg#lucide-star"></use>
								</svg>
							{% else %}
								<svg class="size-3 text-gray-400" viewbox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<use href="/assets/icons/sprite.svg#lucide-star"></use>
								</svg>
							{% endif %}
						{% endfor %}
					</div>
					<span class="mr-3 text-gray-700">{{ rating }}</span>

					<div class="flex items-center text-gray-600">
						<svg class="mr-1 size-3" viewbox="0 0 24 24" stroke="currentColor" fill="none" aria-hidden="true">
							<use href="/assets/icons/sprite.svg#lucide-message-square-text"></use>
						</svg>

						<span>{{ reviewsCount }}</span>
					</div>
				</div>
			</div>
		</section>

		<section class="order-5 lg:col-start-2 lg:row-start-3" aria-label="Description & Reviews">
			<div class="text-collapse-wrapper">
				<div class="text-collapse-content">
					<p class="mt-2 text-base font-bold">
						Опис
					</p>
					<div class="text-block pb-3">
						{{ description }}
					</div>
				</div>
				<div class="text-collapse-overlay"></div>
			</div>

			<button class="collapse-toggle text-primary flex cursor-pointer items-center gap-1 text-left">
				Показати повністю
				{# <svg aria-hidden="true" width="12px" height="12px" viewbox="0 0 24 24">
							<use href="/assets/icons/sprite.svg#icon-caret-down"></use>
						</svg> #}
			</button>

			<div class="flex items-center justify-between">
				<p class="heading-3 my-2">
					Відгуки
				</p>
				<div class="my-1 flex items-center text-sm">
					<div class="mr-2 flex items-center gap-0.5">
						{% for i in 1..5 %}
							{% if rounded_rating >= i %}
								<svg class="size-3 text-orange-600" viewbox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<use href="/assets/icons/sprite.svg#lucide-star"></use>
								</svg>
							{% else %}
								<svg class="size-3 text-gray-400" viewbox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<use href="/assets/icons/sprite.svg#lucide-star"></use>
								</svg>
							{% endif %}
						{% endfor %}
					</div>
					<span class="mr-3 text-gray-700">{{ rating }}</span>

					<div class="flex items-center text-gray-600">
						<svg class="mr-1 size-3" viewbox="0 0 24 24" stroke="currentColor" fill="none" aria-hidden="true">
							<use href="/assets/icons/sprite.svg#lucide-message-square-text"></use>
						</svg>

						<span>{{ reviewsCount }}</span>
					</div>
				</div>
			</div>
			<div class="modal-overlay" data-modal-overlay></div>
			<div class="button-primary mb-4" type="button" data-modal-open="[data-modal]">
				Залишити відгук
			</div>
			<div id="review-list">
				{{ reviews }}
			</div>

			{# MODAL #}

			<div class="modal" data-modal>
				<div class="modal-content">
					<div class="modal-header mb-2">
						<h2 class="modal-title">Додати відгук</h2>
						<button class="button-secondary" type="button" data-type="icon" data-modal-close>
							<svg aria-hidden="true" viewbox="0 0 24 24">
								<use href="/assets/icons/sprite.svg#icon-close"></use>
							</svg>
						</button>
					</div>
					<div class="flex gap-1">
						<img src="{{ thumb }}" alt="{{ heading_title }}" class="max-h-[52px]" />
						<div>
							<h1 class="heading-3">{{ heading_title }}</h1>
							<p class="text-primary">
								{{ author }}
							</p>
						</div>
					</div>

					<div class="modal-body">
						<form id="form-review">
							<div class="form-item">
								<input
									type="text"
									name="name"
									placeholder="Ваше ім'я (відображається на сайті)"
									value="{{ customer_name }}"
									id="input-name"
									class="input"
								/>
							</div>
							<div class="form-item">
								<textarea name="text" placeholder="Введіть коментар" rows="5" id="input-review" class="input"></textarea>
							</div>
							<div class="form-item">
								<label class="form-label">{{ entry_rating }}</label>

								<div class="mt-2 flex items-center gap-1" data-rating>
									{% for i in 1..5 %}
										<button
											type="button"
											class="rating-star cursor-pointer text-gray-300 transition hover:text-orange-500"
											data-value="{{ i }}"
											aria-label="Rating {{ i }}"
										>
											<svg class="size-6" viewBox="0 0 24 24" fill="currentColor">
												<use href="/assets/icons/sprite.svg#lucide-star"></use>
											</svg>
										</button>
									{% endfor %}
								</div>

								<input type="hidden" name="rating" id="input-rating" value="0" />
							</div>

							<div class="form-item">
								<button type="button" id="button-review" data-loading-text="{{ text_loading }}" class="button-primary">
									{{ button_continue }}
								</button>
							</div>
						</form>
					</div>
				</div>
			</div>
		</section>
	</div>
	{# <section aria-label="Related">
			<h2>{{ text_related }}</h2>
			<div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
				{% for product in products %}
					{% include "tailwind/components/product-card.twig" with { product: product } %}
				{% endfor %}
			</div>
		</section> #}

	{{ content_bottom }}
</div>
<script>
	document.addEventListener('DOMContentLoaded', () => {
		$(document).on('click', '.pagination a', function (e) {
			e.preventDefault();

			let url = $(this).attr('href');

			$('#review-list').fadeTo(200, 0.3);

			$.get(url, function (html) {
				$('#review-list').html(html).fadeTo(200, 1);
			});
		});

		const ratingWrapper = document.querySelector('[data-rating]');
		const input = document.getElementById('input-rating');
		const stars = ratingWrapper.querySelectorAll('.rating-star');

		function paint(value) {
			stars.forEach((star, index) => {
				if (index < value) {
					star.classList.add('text-orange-500');
					star.classList.remove('text-gray-300');
				} else {
					star.classList.add('text-gray-300');
					star.classList.remove('text-orange-500');
				}
			});
		}

		stars.forEach((star) => {
			star.addEventListener('click', () => {
				const value = parseInt(star.dataset.value, 10);
				input.value = value;
				paint(value);
			});

			star.addEventListener('mouseenter', () => {
				paint(parseInt(star.dataset.value, 10));
			});
		});

		ratingWrapper.addEventListener('mouseleave', () => {
			paint(parseInt(input.value, 10) || 0);
		});

		$('#button-review').on('click', function () {
			$.ajax({
				url: 'index.php?route=product/product/write&product_id={{ product_id }}',
				type: 'post',
				dataType: 'json',
				data: $('#form-review').serialize(),
				beforeSend: function () {
					$('#button-review').html('Завантаження');
				},
				success: function (json) {
					$('.alert-dismissible').remove();

					if (json['error']) {
						sendToast({ message: json['error'], type: 'error', align: 'right-bottom', timeout: 4000 });
					}

					if (json['success']) {
						closeModal();
						sendToast({ message: json['success'], type: 'success', align: 'right-bottom', timeout: 4000 });

						$('#input-name').val('');
						$('#input-review').val('');
						$('#input-rating').val(0);
					}
				},
			});
		});

		const galleryNode = document.getElementById('product-gallery');

		if (galleryNode) {
			const gallery = EmblaCarousel(galleryNode, {
				loop: true,
			});

			const thumbs = document.querySelectorAll('.gallery-thumb');

			const syncThumbs = () => {
				const selected = gallery.selectedScrollSnap();

				thumbs.forEach((thumb, index) => {
					thumb.classList.toggle('border-primary', index === selected);
					thumb.classList.toggle('border-gray-400', index !== selected);
				});
			};

			thumbs.forEach((thumb) => {
				thumb.addEventListener('click', () => {
					gallery.scrollTo(Number(thumb.dataset.index));
				});
			});

			gallery.on('select', syncThumbs);
			syncThumbs();
		}
	});
</script>
