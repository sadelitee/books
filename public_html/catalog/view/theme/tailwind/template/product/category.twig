{% set class = "col-span-12 " %}
{% if column_left and column_right %}
	{% set class = class ~ "lg:col-span-6" %}
{% elseif column_left or column_right %}
	{% set class = class ~ "lg:col-span-9" %}
{% else %}
	{% set class = class ~ "lg:col-span-12" %}
{% endif %}

<div class="container mx-auto px-2">
	{% include "tailwind/components/breadcrumbs.twig" %}
</div>
<div class="container mx-auto grid grid-cols-1 gap-6 px-2 lg:grid-cols-12">
	{{ column_left }}
	<main class="{{ class }}">
		<div class="flex flex-col justify-between gap-3 pb-5 lg:flex-row">
			<div class="min-sm:items-center flex gap-2 max-sm:flex-col">
				<h1 class="heading mb-0 text-2xl text-neutral-800">
					{% if categories %}
						{% for category in categories %}
							{{ category.name }}
						{% endfor %}
					{% else %}
						{{ heading_title }}
					{% endif %}
				</h1>
				<p class="text-lg text-neutral-500">
					{{ product_count }}
				</p>
			</div>
			{# <hr class="divider"> #}
			<div class="flex items-center gap-5">
				<button id="filterButton" data-size="small" class="button-secondary flex-1 basis-0 border border-neutral-300 lg:hidden">
					<svg>
						<use href="/assets/icons/sprite.svg#lucide-filter"></use>
					</svg>Фільтр
				</button><div class="dropdown flex-1 basis-0" data-type="click" data-align="center">
					<button data-dropdown-button class="button-secondary w-full border border-neutral-300">
						<svg class="rotate-90">
							<use href="/assets/icons/sprite.svg#lucide-arrow-left-right"></use>
						</svg>
						{{ text_sort }}
					</button>

					<div class="dropdown-menu">
						{% for sort in sorts %}
							<button class="dropdown-item w-full px-3 py-2 text-left hover:bg-neutral-100" onclick="location = '{{ sort.href }}'">
								{{ sort.text }}
							</button>
						{% endfor %}
					</div>
				</div>
			</div>
		</div>

		{# {% if categories %}
																			<section class="w-full mb-2" aria-label="Categories">
																				<div class="grid grid-cols-2 xl:grid-cols-3 gap-4">
																					{% for category in categories %}
																						<a href="{{ category.href }}">{{ category.name }}</a>
																					{% endfor %}
																				</div>
																			</section>
																		{% endif %} #}

		{{ content_top }}

		{% if products %}
			<section class="product-grid grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5" aria-label="Products">
				{% for product in products %}
					{% include "tailwind/components/product-card.twig" with { product: product } %}
				{% endfor %}
			</section>

			<section class="my-2 flex justify-between" aria-label="Pagination">
				{{ pagination }}
				{# {{ results }} #}
			</section>
		{% endif %}

		{% if not products %}
			<section class="mx-auto my-8 w-full md:w-1/2" aria-label="Empty">
				<p class="heading">
					{{ text_empty }}
				</p>
				<p>
					{{ text_empty }}
				</p>
				<a href="{{ continue }}" class="button button-primary mt-4">{{ button_continue }}</a>
			</section>
		{% endif %}

		{{ content_bottom }}
	</main>
	{{ column_right }}
</div>
