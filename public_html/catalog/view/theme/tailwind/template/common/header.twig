<header class="header">
	<div class="container flex mx-auto justify-between items-center">
		{% if 'common/home' == route %}
			<img src="{{ logo }}" title="{{ name }}" alt="{{ name }}" style="width:200px"/>
		{% else %}
			<a href="{{ home }}"><img src="{{ logo }}" title="{{ name }}" style="width:200px" alt="{{ name }}"/></a>
		{% endif %}


		{# <button class="flex flex-wrap items-center gap-2 px-4 py-2 text-sm rounded-lg cursor-pointer" onclick="openMenu()"> #}
		<button class="button-primary" onclick="openMenu()">
			<svg aria-hidden="true" class="w-4 h-4" viewbox="0 0 24 24">
				<use href="/assets/icons/sprite.svg#icon-menu"></use>
			</svg>
			<p>Каталог</p>
		</button>

		<div class="flex flex-wrap items-center gap-2">
			{{ currency }}
			{{ language }}
			{{ search }}
			<a href="{{ account }}" class="button-secondary icon">
				<svg aria-hidden="true" viewbox="0 0 24 24">
					<use href="/assets/icons/sprite.svg#icon-user"></use>
				</svg>
				<p class="max-md:hidden">Акаунт</p>
			</a>

			<div data-type="hover" class="relative inline-block group">

				<button data-type="hover" class="button-secondary px-3">
					<svg class="w-5 h-5 flex-shrink-0" viewbox="0 0 24 24" fill="none">
						<use href="/assets/icons/sprite.svg#icon-phone"></use>
					</svg>
					<p>Зв'язатися з нами</p>
					<svg class="w-5 h-5 flex-shrink-0" viewbox="0 0 24 24" fill="none">
						<use href="/assets/icons/sprite.svg#icon-caret-down"></use>
					</svg>
				</button>

				<div
					data-panel class="absolute top-full left-1/2 -translate-x-1/2 w-56 bg-white border border-gray-200 rounded-xl py-1 z-10 opacity-0 scale-y-90 origin-top pointer-events-none transition-all duration-150 ease-out">
					{# Phone #}
					<div class="px-4 py-3 border-b border-gray-100">
						<a href="tel:+380671737379" class="flex items-center gap-2 text-gray-800">
							<div>
								<p class="text-sm font-medium">+ (067) 173 7379</p>
							</div>
						</a>
						<p class="text-xs text-gray-400">Без вихідних</p>
					</div>
					{# Instagram #}
					<div class="px-4 py-2.5 text-sm text-gray-800 border-b border-gray-100 hover:bg-gray-50">
						<a class="flex items-center gap-1" href="https://www.instagram.com/store.booklover/" target="_blank">
							<svg class="w-5 h-5 flex-shrink-0" viewbox="0 0 24 24" fill="none">
								<defs>
									<linearGradient id="ig-grad" x1="0%" y1="100%" x2="100%" y2="0%">
										<stop offset="0%" stop-color="#f9ce34"/>
										<stop offset="50%" stop-color="#ee2a7b"/>
										<stop offset="100%" stop-color="#6228d7"/>
									</linearGradient>
								</defs>
								<g stroke="url(#ig-grad)" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
									<rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
									<path d="M16 11.37A4 4 0 1 1 12.63 8A4 4 0 0 1 16 11.37m1.5-4.87h.01"></path>
								</g>
							</svg>
							<p class="inline-block">Instagram</p>
						</a>
					</div>
					{# Telegram #}
					<div class="px-4 py-2.5 text-sm text-gray-800 border-b border-gray-100 hover:bg-gray-50">
						<a class="flex items-center gap-1" href="https://t.me/store_booklover" target="_blank"><img src="image/catalog/icons/telegram.svg" class="w-5 h-5 inline-block" alt="Telegram"></img>
						<p class="inline-block">Telegram</p>
					</a>
				</div>
			</div>

		</div>
		{{ cart }}
	</div>
</div></header>{{ menu }}


