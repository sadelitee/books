<button class="button-primary icon relative max-md:hidden" data-type="icon" id="cart-button" onclick="openCart()">
	<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewbox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 11l-1 9m5-9l-4-7M2 11h20M3.5 11l1.6 7.4a2 2 0 0 0 2 1.6h9.8a2 2 0 0 0 2-1.6l1.7-7.4M4.5 15.5h15M5 11l4-7m0 7l1 9"/></svg>
	<span id="cart-badge" class="badge absolute top-[-4px] right-[-4px] bg-white text-primary border border-primary" data-size="medium">{{ productCount }}</span>
	<div class="cart-toast" id="cart-toast"></div>
</button>

<div class="sheet p-4" data-side="right" id="cart-modal">
	<div class="sheet-header">
		<p class="heading">{{ text_cart }}</p>
		<button class="button-secondary icon" onclick="closeCart()">
			<svg aria-hidden="true" viewbox="0 0 24 24">
				<use href="/assets/icons/sprite.svg#icon-close"></use>
			</svg>
		</button>
	</div>
	<div class="sheet-content">
		<div class="flex-1" id="cart-modal-products">
			<div class="skeleton h-full w-full"></div>
		</div>

		<div id="cart-modal-totals">
			<div class="skeleton h-25 w-full rounded-md"></div>
		</div>
	</div>
	<div class="flex justify-end gap-2 sheet-footer">
		<button class="button-primary w-full">
			{{ text_checkout }}
		</button>
	</div>
</div>
<div class="sheet-overlay hidden z-30" id="cart-overlay" onclick="closeCart()"></div>
