<footer class="footer">
	<div class="footer-container">
		{% if informations %}
			<div>
				<p class="footer-title">
					{{ text_information }}
				</p>
				{% for information in informations %}
					<a href="{{ information.href }}" class="footer-link">{{ information.title }}</a>
				{% endfor %}
			</div>
		{% endif %}

		<div>
			<p class="footer-title">
				{{ text_service }}
			</p>
			<a href="{{ contact }}" class="footer-link">{{ text_contact }}</a>
			<a href="{{ return }}" class="footer-link">{{ text_return }}</a>
			<a href="{{ sitemap }}" class="footer-link">{{ text_sitemap }}</a>
		</div>

		<div>
			<p class="footer-title">
				{{ text_extra }}
			</p>
			<a href="{{ manufacturer }}" class="footer-link">{{ text_manufacturer }}</a>
			<a href="{{ voucher }}" class="footer-link">{{ text_voucher }}</a>
			<a href="{{ affiliate }}" class="footer-link">{{ text_affiliate }}</a>
			<a href="{{ special }}" class="footer-link">{{ text_special }}</a>
		</div>

		<div>
			<p class="footer-title">
				{{ text_account }}
			</p>
			<a href="{{ account }}" class="footer-link">{{ text_account }}</a>
			<a href="{{ order }}" class="footer-link">{{ text_order }}</a>
			<a href="{{ wishlist }}" class="footer-link">{{ text_wishlist }}</a>
			<a href="{{ newsletter }}" class="footer-link">{{ text_newsletter }}</a>
		</div>
	</div>
	<hr class="divider my-4"/>
	<div class="footer-container">
		<p class="text-sm text-neutral-600 dark:text-neutral-300">
			{{ powered }}
		</p>
	</div>
</footer>


{# mobile menu #}

<nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 flex items-center justify-around px-2 py-2 z-10 md:hidden">

	<a href="{% if 'common/home' == route %}/{% else %}{{ home }}{% endif %}" class="flex flex-col items-center gap-1 text-xs text-primary px-3 py-1">
		<svg class="w-6 h-6" viewbox="0 0 24 24" fill="none">
			<use href="/assets/icons/sprite.svg#lucide-house"></use>
		</svg>
		<span>Головна</span>
	</a>

	<div onclick="openMenu()" class="flex flex-col items-center gap-1 text-xs text-primary px-3 py-1">
		<svg class="w-6 h-6" viewbox="0 0 24 24" fill="none">
			<use href="/assets/icons/sprite.svg#icon-menu"></use>
		</svg>
		<span>Каталог</span>
	</div>

	<button onclick="openCart()" class="flex flex-col items-center gap-1 text-xs text-primary px-3 py-1 relative">
		<div class="relative">
			<svg class="w-6 h-6" viewbox="0 0 24 24" fill="none">
				<use href="/assets/icons/sprite.svg#icon-cart"></use>
			</svg>
			<span id="mobile-cart-badge" class="badge absolute top-[-4px] right-[-4px] bg-white text-primary border border-primary" data-size="small"></span>
		</div>
		<span>Кошик</span>
	</button>

	{# <a href="/wishlist" class="flex flex-col items-center gap-1 text-xs text-gray-500 hover:text-primary px-3 py-1">
																		<svg class="w-6 h-6" viewbox="0 0 24 24" fill="none">
																			<use href="/assets/icons/sprite.svg#icon-heart"></use>
																		</svg>
																		<span>Обране</span>
																	</a> #}

	<a href="/my-account" class="flex flex-col items-center gap-1 text-xs text-primary px-3 py-1">
		<svg class="w-6 h-6" viewbox="0 0 24 24" fill="none">
			<use href="/assets/icons/sprite.svg#icon-user"></use>
		</svg>
		<span>Кабінет</span>
	</a>

</nav>

